# PostgreSQL
DATABASE_URL=postgres://promptops:promptops@localhost:5432/promptops

# API auth — single token for MVP
PROMPTOPS_API_TOKEN=change-me-to-a-long-random-string

# Server
PORT=3030
NODE_ENV=development
LOG_LEVEL=info

# LLM Provider — OpenAI for MVP
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Cost controls
MAX_USD_PER_RUN=1.00
MAX_USD_PER_DAY=10.00
